<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>תשלום מאובטח - Checkout</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&display=swap');
        
        body {
            font-family: 'Assistant', sans-serif;
            background-color: #f8fafc;
        }

        .gradient-brand {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
        }

        .trust-badge {
            transition: all 0.3s ease;
        }

        .trust-badge:hover {
            transform: translateY(-2px);
        }

        #paypal-button-container {
            margin-top: 20px;
        }

        .security-icon {
            color: #059669;
        }
    </style>
</head>
<body class="text-gray-800">

    <div class="max-w-6xl mx-auto px-4 py-8 lg:py-16">
        <!-- Header / Logo -->
        <div class="flex flex-col items-center mb-10">
            <div class="w-16 h-16 gradient-brand rounded-full flex items-center justify-center text-white mb-4 shadow-lg">
                <i class="fas fa-shield-alt text-3xl"></i>
            </div>
            <h1 class="text-3xl font-bold text-gray-900">תשלום מאובטח</h1>
            <p class="text-gray-500 mt-2">העסקה שלך מוצפנת ומאובטחת בטכנולוגיית SSL</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            
            <!-- Side A: Order Summary (Visible first on Mobile) -->
            <div class="lg:col-span-5 lg:order-2">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden sticky top-8">
                    <div class="p-6 bg-gray-50 border-b border-gray-100">
                        <h2 class="text-xl font-bold">סיכום הזמנה</h2>
                    </div>
                    
                    <div class="p-6 space-y-4">
                        <!-- Product Item -->
                        <div class="flex items-center gap-4">
                            <div class="w-20 h-20 bg-gray-200 rounded-lg flex-shrink-0 overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=200&h=200&fit=crop" alt="מוצר" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-grow">
                                <h3 class="font-semibold text-gray-800">חבילת פרימיום VIP</h3>
                                <p class="text-sm text-gray-500">גישה מלאה לכל התכנים</p>
                            </div>
                            <div class="text-left font-bold text-gray-900">
                                ₪299
                            </div>
                        </div>

                        <hr class="border-gray-100">

                        <!-- Calculations -->
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between">
                                <span class="text-gray-600">מחיר מוצר</span>
                                <span>₪255.55</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">מע"מ (17%)</span>
                                <span>₪43.45</span>
                            </div>
                            <div class="flex justify-between font-bold text-lg mt-4 pt-4 border-t border-gray-100">
                                <span>סה"כ לתשלום</span>
                                <span class="text-emerald-600">₪299.00</span>
                            </div>
                        </div>
                    </div>

                    <!-- Trust Signals in Summary -->
                    <div class="p-6 bg-emerald-50 flex items-center gap-3">
                        <i class="fas fa-lock security-icon"></i>
                        <span class="text-sm text-emerald-800 font-medium">רכישה בטוחה עם הגנת קונה מלאה</span>
                    </div>
                </div>
            </div>

            <!-- Side B: Checkout Form -->
            <div class="lg:col-span-7 lg:order-1">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:p-8">
                    
                    <!-- Form Header -->
                    <div class="mb-8">
                        <h2 class="text-2xl font-bold mb-2">פרטי תשלום</h2>
                        <p class="text-gray-500 text-sm">אנא מלא את הפרטים הבאים לסיום הרכישה</p>
                    </div>

                    <!-- Payment Options -->
                    <div class="space-y-6">
                        <!-- Secure Payment Button Container -->
                        <div id="payment-methods" class="space-y-4">
                            <div class="flex items-center justify-between p-4 border-2 border-emerald-500 rounded-xl bg-emerald-50">
                                <div class="flex items-center gap-3">
                                    <div class="w-5 h-5 rounded-full border-4 border-emerald-500"></div>
                                    <span class="font-bold">תשלום מאובטח (PayPal / אשראי)</span>
                                </div>
                                <div class="flex gap-2 text-2xl text-gray-400">
                                    <i class="fab fa-cc-visa"></i>
                                    <i class="fab fa-cc-mastercard"></i>
                                    <i class="fab fa-paypal text-blue-800"></i>
                                </div>
                            </div>

                            <!-- Real PayPal Integration Placeholder -->
                            <div id="paypal-button-container"></div>
                            
                            <div class="text-center">
                                <span class="text-xs text-gray-400 uppercase tracking-widest font-bold">או</span>
                            </div>

                            <!-- Manual Form (Visual Only) -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold">שם מלא</label>
                                    <input type="text" placeholder="ישראל ישראלי" class="w-full p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-semibold">אימייל למשלוח קבלה</label>
                                    <input type="email" placeholder="name@example.com" class="w-full p-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-emerald-500 outline-none">
                                </div>
                            </div>
                        </div>

                        <!-- Safety Badges -->
                        <div class="pt-10 border-t border-gray-100 mt-10">
                            <div class="flex flex-wrap justify-center gap-8 items-center opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
                                <div class="flex flex-col items-center gap-1">
                                    <i class="fas fa-user-shield text-2xl"></i>
                                    <span class="text-[10px] font-bold">PCI COMPLIANT</span>
                                </div>
                                <div class="flex flex-col items-center gap-1">
                                    <i class="fas fa-check-circle text-2xl"></i>
                                    <span class="text-[10px] font-bold">VERIFIED BY VISA</span>
                                </div>
                                <div class="flex flex-col items-center gap-1">
                                    <i class="fas fa-lock text-2xl"></i>
                                    <span class="text-[10px] font-bold">SSL ENCRYPTED</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Footer -->
        <footer class="mt-16 text-center text-gray-400 text-sm">
            <p>© 2024 כל הזכויות שמורות. תשלום זה מעובד על ידי שרת מאובטח.</p>
            <div class="flex justify-center gap-4 mt-2">
                <a href="#" class="hover:underline">תנאי שימוש</a>
                <span>•</span>
                <a href="#" class="hover:underline">מדיניות פרטיות</a>
                <span>•</span>
                <a href="#" class="hover:underline">ביטול עסקה</a>
            </div>
        </footer>
    </div>

    <!-- Script to simulate the PayPal button look -->
    <script>
        // זהו רק ייצוג ויזואלי של הכפתור המקצועי
        document.addEventListener('DOMContentLoaded', function() {
            const container = document.getElementById('paypal-button-container');
            container.innerHTML = `
                <div class="space-y-3">
                    <button class="w-full bg-[#ffc439] hover:bg-[#f2ba36] text-black font-bold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-colors">
                        <i class="fab fa-paypal text-xl"></i>
                        תשלום באמצעות PayPal
                    </button>
                    <button class="w-full bg-black hover:bg-gray-800 text-white font-bold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-colors">
                        תשלום בכרטיס אשראי
                    </button>
                </div>
            `;
        });
    </script>
</body>
</html>
