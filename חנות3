    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize AOS
        AOS.init({ duration: 1000, once: true, offset: 100, easing: 'ease-out-cubic' });
        lucide.createIcons();

        // --- מערכת ניהול ענן (Cloud Backend Integration) ---
        let db, auth, userId, appId;
        let collectionRef, addDoc, serverTimestamp;

        async function initManagementSystem() {
            try {
                // טעינה דינמית של ספריות מסד הנתונים מבלי לשבור את הפונקציות הקיימות באתר
                const [appModule, authModule, firestoreModule] = await Promise.all([
                    import('https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js'),
                    import('https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js'),
                    import('https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js')
                ]);

                const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {};
                const app = appModule.initializeApp(firebaseConfig);
                auth = authModule.getAuth(app);
                db = firestoreModule.getFirestore(app);
                appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
                
                collectionRef = firestoreModule.collection;
                addDoc = firestoreModule.addDoc;
                serverTimestamp = firestoreModule.serverTimestamp;

                authModule.onAuthStateChanged(auth, (user) => {
                    if (user) userId = user.uid;
                });

                // אימות אנונימי ומוצפן מול השרת
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await authModule.signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await authModule.signInAnonymously(auth);
                }
                console.log("מערכת הניהול המאובטחת מחוברת בהצלחה.");
            } catch (error) {
                console.error("שגיאה בחיבור למערכת הניהול:", error);
            }
        }
        initManagementSystem();

        let cart = [];
        let currentCurrency = 'USD';
        let paypalButtonRendered = false;

        function toggleCart() {
            const drawer = document.getElementById('cart-drawer');
            drawer.classList.toggle('translate-x-full');
            // Prevent body scroll when cart is open
            document.body.style.overflow = drawer.classList.contains('translate-x-full') ? 'auto' : 'hidden';
        }

        function configAndAdd(baseName, basePrice, scriptId, hiddurId) {
            const script = document.getElementById(scriptId).value;
            const hiddurVal = parseInt(document.getElementById(hiddurId).value);
            const finalPrice = basePrice + hiddurVal;
            const fullName = `${baseName} (${script})`;
            
            addToCart(fullName, finalPrice);
        }

        function addToCart(name, price) {
            cart.push({ name, price, id: Date.now() });
            updateCart();
            if(document.getElementById('cart-drawer').classList.contains('translate-x-full')) toggleCart();
        }

        function removeFromCart(id) {
            cart = cart.filter(i => i.id !== id);
            updateCart();
        }

        function updateCart() {
            const container = document.getElementById('cart-items');
            const totalDisplay = document.getElementById('cart-total');
            const countDisplay = document.getElementById('cart-count');
            const progress = document.getElementById('shipping-progress');
            const status = document.getElementById('shipping-status');
            
            container.innerHTML = '';
            let total = 0;
            
            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center py-24 text-center">
                        <i data-lucide="shopping-bag" class="w-12 h-12 text-navy/5 mb-6"></i>
                        <div class="text-navy/20 italic font-serif text-lg">הסל ריק כרגע...</div>
                    </div>`;
                progress.style.width = '0%';
                status.innerText = 'משלוח חינם מעל $1,000';
                if(paypalButtonRendered) {
                    document.getElementById('paypal-button-container').innerHTML = '';
                    paypalButtonRendered = false;
                }
            } else {
                cart.forEach(item => {
                    total += item.price;
                    const el = document.createElement('div');
                    el.className = 'flex justify-between items-start group animate-fade-in border-b border-gold/5 pb-6';
                    el.innerHTML = `
                        <div class="flex-1">
                            <div class="font-serif font-black text-navy text-xl italic leading-tight">${item.name}</div>
                            <div class="text-gold font-bold text-[10px] tracking-widest mt-2">${formatPrice(item.price)}</div>
                        </div>
                        <button onclick="removeFromCart(${item.id})" class="text-navy/10 hover:text-red-500 transition-colors p-1"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    `;
                    container.appendChild(el);
                });
                
                // Progress Bar Logic
                const percent = Math.min((total / 1000) * 100, 100);
                progress.style.width = percent + '%';
                status.innerText = total >= 1000 ? 'מזל טוב! זכיתם במשלוח חינם' : `עוד ${formatPrice(1000 - total)} למשלוח חינם`;
                
                lucide.createIcons();
                renderPayPal(total);
            }
            
            totalDisplay.innerText = formatPrice(total);
            countDisplay.innerText = cart.length;
        }

        function formatPrice(val) {
            if (currentCurrency === 'ILS') {
                return '₪' + (val * 3.75).toLocaleString();
            }
            return '$' + val.toLocaleString();
        }

        function setCurrency(curr) {
            currentCurrency = curr;
            document.getElementById('btn-usd').classList.toggle('bg-gold', curr === 'USD');
            document.getElementById('btn-usd').classList.toggle('text-white', curr === 'USD');
            document.getElementById('btn-ils').classList.toggle('bg-gold', curr === 'ILS');
            document.getElementById('btn-ils').classList.toggle('text-white', curr === 'ILS');
            updateCart();
        }

        function renderPayPal(amount) {
            if (paypalButtonRendered) return;
            const container = document.getElementById('paypal-button-container');
            container.innerHTML = '';
            
            paypal.Buttons({
                style: { layout: 'vertical', color: 'gold', shape: 'rect', label: 'pay' },
                createOrder: (data, actions) => actions.order.create({ purchase_units: [{ amount: { value: amount.toString() } }] }),
                onApprove: (data, actions) => actions.order.capture().then(async details => {
                    
                    // --- שמירת ההזמנה במערכת הניהול ---
                    if (userId && db) {
                        try {
                            const ordersRef = collectionRef(db, 'artifacts', appId, 'users', userId, 'orders');
                            await addDoc(ordersRef, {
                                items: cart,
                                totalAmount: amount,
                                currency: currentCurrency,
                                customerName: details.payer.name.given_name + ' ' + details.payer.name.surname,
                                orderDate: serverTimestamp(),
                                status: 'paid'
                            });
                            console.log("ההזמנה נשמרה וסונכרנה במערכת הניהול.");
                        } catch (e) {
                            console.error("תקלה בסנכרון ההזמנה למערכת:", e);
                        }
                    }

                    alert('תודה! הזמנתכם התקבלה בהצלחה ותועבר לטיפול סופר סת"ם.');
                    cart = []; updateCart(); toggleCart();
                })
            }).render('#paypal-button-container');
            paypalButtonRendered = true;
        }

        // Optimized Parallax
        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            const parallax = document.querySelector('.parallax-bg');
            if(parallax && window.innerWidth > 768) {
                parallax.style.transform = `translateY(${scrolled * 0.4}px) scale(1.1)`;
            }
            
            const nav = document.getElementById('main-nav');
            if (scrolled > 60) {
                nav.classList.add('scrolled');
                nav.style.padding = '12px 24px';
            } else {
                nav.classList.remove('scrolled');
                nav.style.padding = '20px 48px';
            }
        });

        function setLanguage(lang) {
            // Simplified for demo
            console.log('Language set to: ' + lang);
        }

        // Initialize currency button UI
        setCurrency('USD');
    </script>
