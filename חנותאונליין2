    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
        lucide.createIcons();

        let cart = [];
        let currentCurrency = 'USD';

        function toggleCart() {
            document.getElementById('cart-drawer').classList.toggle('-translate-x-full');
        }

        function addToCart(name, price) {
            cart.push({ name, price, id: Date.now() });
            updateCart();
            if(document.getElementById('cart-drawer').classList.contains('-translate-x-full')) toggleCart();
        }

        function removeFromCart(id) {
            cart = cart.filter(i => i.id !== id);
            updateCart();
        }

        function updateCart() {
            const container = document.getElementById('cart-items');
            const totalDisplay = document.getElementById('cart-total');
            const countDisplay = document.getElementById('cart-count');
            
            container.innerHTML = '';
            let total = 0;
            
            if (cart.length === 0) {
                container.innerHTML = '<div class="text-center text-gray-400 mt-20 opacity-50"><i data-lucide="shopping-bag" class="w-16 h-16 mx-auto mb-4"></i><p>הסל שלך ממתין ליצירות קודש</p></div>';
            } else {
                cart.forEach(item => {
                    total += item.price;
                    const el = document.createElement('div');
                    el.className = 'flex justify-between items-center bg-navy/5 p-4 rounded border border-gold/10';
                    el.innerHTML = `
                        <div>
                            <div class="font-bold text-navy text-sm">${item.name}</div>
                            <div class="text-gold font-bold">${currentCurrency === 'USD' ? '$' : '₪'}${currentCurrency === 'USD' ? item.price : (item.price * 3.75).toFixed(0)}</div>
                        </div>
                        <button onclick="removeFromCart(${item.id})" class="text-gray-400 hover:text-red-600 transition-colors"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    `;
                    container.appendChild(el);
                });
            }
            
            totalDisplay.innerText = `${currentCurrency === 'USD' ? '$' : '₪'}${currentCurrency === 'USD' ? total.toLocaleString() : (total * 3.75).toLocaleString()}`;
            countDisplay.innerText = cart.length;
            lucide.createIcons();
            renderPayPal(total);
        }

        let paypalButton;
        function renderPayPal(amount) {
            const container = document.getElementById('paypal-button-container');
            if (amount <= 0 || paypalButton) {
                if (amount <= 0) container.innerHTML = '';
                return;
            }
            
            paypal.Buttons({
                createOrder: (data, actions) => actions.order.create({ purchase_units: [{ amount: { value: amount.toString() } }] }),
                onApprove: (data, actions) => actions.order.capture().then(details => {
                    alert('תודה על רכישתך, ' + details.payer.name.given_name);
                    cart = []; updateCart(); toggleCart();
                })
            }).render('#paypal-button-container');
            paypalButton = true;
        }

        function setCurrency(curr) {
            currentCurrency = curr;
            // Update all prices on page
            document.querySelectorAll('[data-price-ils]').forEach(el => {
                const usd = parseFloat(el.innerText.replace('$', '').replace(',', ''));
                const ils = el.getAttribute('data-price-ils');
                el.innerText = curr === 'USD' ? `$${usd.toLocaleString()}` : `₪${parseFloat(ils).toLocaleString()}`;
            });
            updateCart();
        }
    </script>
